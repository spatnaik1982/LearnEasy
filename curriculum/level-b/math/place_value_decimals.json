  "learningObjective": "Identify place values in decimal numbers",
  "coreIdea": "The position of a digit in a decimal determines its value.",
  "examples": [
    "In 125.021, 2 is in the tenths place",
    "In 0.005, 5 is in the thousandths place",
    "In 3.14, 1 is in the hundredths place"
  ],
