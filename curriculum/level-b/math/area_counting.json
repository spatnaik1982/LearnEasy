{
  "conceptId": "area_counting",
  "chapter": {
    "code": "CH3",
    "name": "Understanding Area"
  },
  "learningObjective": "Count the area of shapes on a grid",
  "coreIdea": "Area is the number of unit squares that cover a shape.",
  "examples": [
    "A rectangle that is 3 units by 2 units has an area of 6 unit squares. 🔲",
    "A square that is 2 units by 2 units has an area of 4 unit squares. 🔲",
    "A shape that covers 5 unit squares has an area of 5. 🔲"
  ],
  "misconceptions": [
    "Students may confuse area with perimeter when counting on a grid.",
    "Students may count the edges instead of the squares for area.",
    "Students may count the same square twice when finding the area."
  ],
  "supports": {
    "visual": true
  },
  "masteryCriteria": 0.8,
  "difficulty": "beginner",
  "estimatedDuration": 20,
  "dependencies": [
    "area_intro",
    "counting_1_10"
  ],
