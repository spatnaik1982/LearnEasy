  "conceptId": "percentages_intro",
  "chapter": {
    "code": "CH4",
    "name": "Understanding Percentages"
  },
  "learningObjective": "Convert fractions and decimals to percentages",
  "coreIdea": "Percentages represent parts per hundred and can be derived from fractions and decimals.",
  "examples": [
    "1/100 = 1%",
    "0.5 = 50%",
    "0.25 = 25%"
  ],
  "misconceptions": [
    "Students may confuse percentages with fractions, thinking they are the same without understanding the conversion process.",
    "Students might believe that all decimals can be easily converted to percentages without recognizing the need for multiplication by 100.",
    "Some learners may think that percentages can only be derived from whole numbers, not realizing that fractions and decimals can also represent parts of a whole."
  ],
