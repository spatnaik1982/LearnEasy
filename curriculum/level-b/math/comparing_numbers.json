{
  "conceptId": "comparing_numbers",
  "chapter": {
    "code": "CH1",
    "name": "Understanding Numbers and Comparison"
  },
  "learningObjective": "Compare two or more numbers",
  "coreIdea": "Students will learn to determine which numbers are larger or smaller.",
  "examples": [
    "5 > 3 (five is greater than three)",
    "81,59,632 < 9,86,54,321",
    "970 < 976"
  ],
  "misconceptions": [
    "Students may confuse the symbols for greater than and less than.",
    "Students might think that the number of digits determines which number is larger.",
    "Some students may believe that numbers with more digits are always larger, regardless of their actual value."
  ],
