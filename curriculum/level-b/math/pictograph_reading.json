    "code": "CH7",
    "name": "Data Handling"
  },
  "learningObjective": "Read and interpret pictographs",
  "coreIdea": "Pictographs use pictures or symbols to represent data.",
  "examples": [
    "A pictograph shows 8 apples using 8 apple symbols. 📊",
    "A pictograph shows 5 bananas using 5 banana symbols. 📊",
    "A pictograph shows 3 cherries using 3 cherry symbols. 📊"
  ],
  "misconceptions": [
    "Students may think each symbol represents more than one item when it represents exactly one.",
    "Students may confuse pictographs with bar graphs.",
    "Students may ignore the legend or key when reading a pictograph."
  ],
  "supports": {
    "visual": true
  },
  "masteryCriteria": 0.8,
  "difficulty": "beginner",
