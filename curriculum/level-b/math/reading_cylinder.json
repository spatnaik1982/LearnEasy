  "learningObjective": "Read a measuring cylinder in millilitres",
  "coreIdea": "A measuring cylinder shows the volume of liquid in millilitres.",
  "examples": [
    "200 mL of water reaches the 200 mark on the cylinder. 🧪",
    "350 mL of juice reaches the 350 mark on the cylinder. 🧪",
    "400 mL of milk reaches the 400 mark on the cylinder. 🧪"
  ],
  "misconceptions": [
    "Students may read the bottom of the meniscus instead of the top of the liquid.",
    "Students may think the cylinder measures weight instead of volume.",
    "Students may confuse mL with L when reading the scale."
  ],
