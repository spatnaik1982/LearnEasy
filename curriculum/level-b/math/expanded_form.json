  "chapter": {
    "code": "CH1",
    "name": "Understanding Numbers from 1000 to 9999"
  },
  "learningObjective": "Write numbers in expanded form",
  "coreIdea": "Expanded form shows the sum of each digit's place value.",
  "examples": [
    "75406 = 70000 + 5000 + 400 + 0 + 6",
    "87965 = 80000 + 7000 + 900 + 60 + 5",
    "395432 = 300000 + 90000 + 5000 + 400 + 30 + 2"
  ],
  "misconceptions": [
    "Students may confuse expanded form with standard form, thinking they are the same.",
    "Students might believe that expanded form only applies to numbers with non-zero digits in every place value.",
    "Some students may think that expanded form is just writing the number out in words rather than showing the sum of place values."
  ],
