{
  "conceptId": "place_value_understanding",
  "chapter": {
    "code": "CH1",
    "name": "Understanding Place Values"
  },
  "learningObjective": "Identify place values of digits in numbers",
  "coreIdea": "Students will recognize the value of each digit based on its position.",
  "examples": [
    "In 5964, 9 is 900 (hundreds)",
    "In 18,342, 3 is 3,000 (thousands)",
    "In 807695, 0 is 0 (tens)"
  ],
  "misconceptions": [
    "Students may confuse the place value of digits, thinking that the value is the same regardless of position.",
    "Students might overlook the value of zero in a number, believing it contributes to the total value.",
    "Students may struggle to translate numbers into words accurately, leading to incorrect representations."
  ],
  "supports": {
    "visual": true
  },
  "masteryCriteria": 0.8,
  "difficulty": "beginner",
  "estimatedDuration": 25,
  "dependencies": [
