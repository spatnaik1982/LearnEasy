# Database
DATABASE_URL="postgresql://user:***@localhost:5432/learneasy"

# OpenAI (for AI Tutor + Curriculum Pipeline)
OPENAI_API_KEY=***

# LLM Provider Configuration (for Curriculum Pipeline — EPIC-13)
# Select provider: "openai" or "anthropic" (default: openai)
LLM_PROVIDER=openai
# Model name (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
# Optional: falls back to OPENAI_API_KEY or ANTHROPIC_API_KEY
LLM_API_KEY=
# Max tokens for generation (default: 4096)
LLM_MAX_TOKENS=4096
# Temperature for generation (default: 0.3)
LLM_TEMPERATURE=0.3

# JWT Secret (for auth)
JWT_SECRET="change-me-to-a-random-string"

# Student App
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_USE_MOCK="true"
